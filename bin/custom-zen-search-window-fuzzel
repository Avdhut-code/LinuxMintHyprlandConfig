#!/bin/sh

# Launch fuzzel in dmenu mode
# Width 30 and Lines 1 makes it look like a sleek search bar
# 0.95 transparency = f2 alpha
QUERY=$(fuzzel -d \
    --prompt=" # Search : " \
    --width=30 \
    --lines=1 \
    --font="Sans:size=12" \
    --background=000000f2 \
    --text=ffffffff \
    --selection-text=ffffffff \
    --border-width=2 \
    --border-color=333333ff )

# Exit if the user hits Escape or enters nothing
[ -z "$QUERY" ] && exit 0

# Switch workspace
hyprctl dispatch workspace 2

# Open in Zen
zen --new-tab "https://google.com/search?q=$QUERY"
