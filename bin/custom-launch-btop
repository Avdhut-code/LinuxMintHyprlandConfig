#!/usr/bin/env bash
# btop-launch.sh
# Launch btop inside Kitty terminal with proper UTF-8 and cleanup

# Exit immediately if a command fails
set -e

# Check if Kitty is installed
if ! command -v gnome-terminal &>/dev/null; then
  echo "Error: kitty is not installed or not in PATH." >&2
  exit 1
fi

# Check if btop is installed
if ! command -v btop &>/dev/null; then
  echo "Error: btop is not installed or not in PATH." >&2
  exit 1
fi

# Run btop in a new Kitty window with UTF-8 mode forced
gnome-terminal --class=custom-launch-btop --title="btop Moniter" --command="btop --utf-force"
