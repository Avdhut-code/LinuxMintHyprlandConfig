#!/bin/bash

### --- Start swaybg
swaybg -i "$CURRENT_WALLPAPER" -m fill &
sleep 1 # extra stability buffer

### --- Start waybar
waybar >/dev/null 2>&1 &
sleep 1 # extra stability buffer

### --- Start hypridle
hypridle >/dev/null 2>&1 &
sleep 1 # extra stability buffer

#### --- ***NOW EVERYTHING IS RUNNING AND STABLE***
#kitty \
