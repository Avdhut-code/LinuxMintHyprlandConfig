#!/bin/bash

# script version
VERSION="1.0.0"

# default video file
DEFAULT_FILE="/home/its_avdhut/Music/shinji-s-mom-sings-u-komm-susser-tod-by-juliuan-chahayed-yt.m4a" 

# how help
show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -h, --help          Show this help message"
    echo "  -v, --version       Show the script version"
    echo "  --play [FILE]       Play the specified video file using Celluloid"
    echo ""
    echo "Examples:"
    echo "  $0 --play  /path/to/video.mp4"
    echo "  $0 --play, -p           Play the default video"
    echo "  $0 --version , -v"
}

# play a mp4 or mp3 
play_video() {
    FILE="$1"
    if [ -z "$FILE" ]; then
        echo "No file provided. Falling back to the default video: $DEFAULT_FILE"
        FILE="$DEFAULT_FILE"
    fi

    if [ -f "$FILE" ]; then
        echo "Playing video: $FILE"
        # Run Celluloid in the background, ensuring it continues after the terminal is closed
	nohup mpv "$FILE" > /dev/null 2>&1 &
	# nohup celluloid --new-window "$FILE" > /dev/null 2>&1 &
        echo "Video is playing in the background. You can close the terminal."
    else
        echo "Error: File '$FILE' does not exist. Please check the path or update the default file."
        exit 1
    fi
}

# Parse command-line arguments
if [ "$#" -eq 0 ]; then
    echo "Error: No arguments provided."
    show_help
    exit 1
fi

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            echo "$0 version $VERSION"
            exit 0
            ;;
        --play | -p )
            # Check if the next argument is provided and not another option
            if [[ -n "$2" && ! "$2" =~ ^- ]]; then
                play_video "$2"
                shift
            else
                play_video # Play the default video
            fi
            ;;
        *)
            echo "Error: Unknown option '$1'"
            show_help
            exit 1
            ;;
    esac
    shift
done

